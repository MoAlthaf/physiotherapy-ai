# ===== Fanar API configuration =====
# Put your real API key here (no quotes). Get it from https://api.fanar.qa
FANAR_API_KEY=""

# Base URL for the OpenAI-compatible Fanar API
FANAR_BASE_URL=""

# Chat model to test against (change if you want a different Fanar model)
FANAR_MODEL="Fanar"

# Sampling params
TEMPERATURE=0.7
MAX_TOKENS=1024

# Replay mode:
#   live     = ignore the batch's assistant turns; history = Fanar's own replies
#   scripted = feed the batch's demo assistant turns as priming context
#              (replays the authored jailbreak, with its agreeable lead-in)
MODE=scripted

# Optional system prompt sent as the first message (leave empty for none).
# Useful to mimic the website's setup. One line.
SYSTEM_PROMPT=You are a helpful assistant.
